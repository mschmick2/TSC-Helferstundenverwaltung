{
    "name": "vaes/helferstundenverwaltung",
    "description": "VAES - Vereins-Arbeitsstunden-Erfassungssystem",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "chillerlan/php-qrcode": "^5.0",
        "monolog/monolog": "^3.5",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "phpmailer/phpmailer": "^6.9",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "spomky-labs/otphp": "^11.0",
        "tecnickcom/tcpdf": "^6.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "../tests/"
        }
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "scripts": {
        "test":             "cd .. && src/vendor/bin/phpunit",
        "test:unit":        "cd .. && src/vendor/bin/phpunit --testsuite Unit",
        "test:integration": "cd .. && src/vendor/bin/phpunit --testsuite Integration",
        "test:feature":     "cd .. && src/vendor/bin/phpunit --testsuite Feature",
        "test:security":    "cd .. && src/vendor/bin/phpunit --testsuite Security",
        "test:coverage":    "cd .. && src/vendor/bin/phpunit --coverage-html storage/coverage",
        "setup:test-db":    "cd .. && php scripts/setup-test-db.php",
        "analyse":          "phpstan analyse app --level=6 --no-progress",
        "cs:check":         "phpcs --standard=PSR12 app --ignore=app/Views",
        "cs:fix":           "phpcbf --standard=PSR12 app --ignore=app/Views",
        "quality":          ["@cs:check", "@analyse", "@test"]
    },
    "scripts-descriptions": {
        "test":             "Alle Testsuites ausfuehren",
        "test:unit":        "Nur Unit-Tests (keine DB)",
        "test:integration": "Integration-Tests (benoetigen vaes_test DB)",
        "test:feature":     "Feature-Tests (HTTP-Roundtrip + vaes_test DB)",
        "test:security":    "Security-Tests (OWASP-Checks)",
        "test:coverage":    "Coverage-HTML-Report -> storage/coverage/",
        "setup:test-db":    "Test-DB-Schema aus Dev-DB klonen",
        "analyse":          "PHPStan statische Analyse",
        "cs:check":         "PSR-12 Code-Style-Check",
        "cs:fix":           "PSR-12 Auto-Fix",
        "quality":          "Voller Quality-Gate (CS + PHPStan + Tests)"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
