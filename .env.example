# VAES — Environment-Variablen (lokal / CI)
# Kopiere als .env und passe an. NICHT committen.

# === Datenbank ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=vaes
DB_TEST_DATABASE=vaes_test

# === SMTP / MailPit (lokal) ===
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=
SMTP_FROM_ADDRESS=noreply@vaes.test
SMTP_FROM_NAME="VAES Test"
MAILPIT_URL=http://127.0.0.1:8025

# === App ===
APP_ENV=development
APP_BASE_URL=http://localhost:8000

# === Strato-DB-Import (einmalig, siehe docs/Testumgebung.md) ===
# Pfad zur phpMyAdmin-Export-Datei fuer import-strato-db.php
STRATO_DUMP_PATH=storage/strato-dumps/vaes-prod-latest.sql

# Testuser-Zugangsdaten (Default-Passwort, kann pro Maschine ueberschrieben werden)
TEST_USER_PASSWORD=TestPass123!
